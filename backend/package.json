{
  "name": "fluentkeys-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node-pg-migrate -m migrations --envPath ../.env",
    "migrate:prod": "node-pg-migrate -m migrations up"
  },
  "dependencies": {
    "@clerk/express": "^2.1.26",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "node-pg-migrate": "^7.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

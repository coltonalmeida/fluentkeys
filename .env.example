# Backend
PORT=3001
# Postgres connection. Create a free cloud database on Supabase (supabase.com)
# or Neon (neon.tech), paste its connection string here, and set PGSSL=true.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=no-verify
# Hosted Postgres (Supabase/Neon/Render) requires TLS.
PGSSL=true
# Optional but recommended in production: the DB provider's CA certificate (PEM,
# as a single-line string with \n escapes). When set, TLS is fully verified
# instead of encrypted-but-unverified. Leave unset for local/dev.
# PGCA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n"
# Clerk (dashboard.clerk.com → your app → API keys)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Clerk webhook signing secret (dashboard.clerk.com → Webhooks → your endpoint
# → Signing Secret). Used to verify the user.deleted webhook that wipes a
# deleted account's data. Create an endpoint pointing at
# <backend-url>/webhooks/clerk subscribed to the user.deleted event.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Production only:
# Comma-separated list of allowed browser origins. REQUIRED in production
# (NODE_ENV=production) — the server refuses to start without it. Unset = allow
# all (local dev only).
# CORS_ORIGIN=https://your-frontend-domain.com

# Deployed frontend origin. Used by the shareable result page (§1): the backend
# serves /r/:id with Open Graph meta for crawlers and redirects humans here to the
# SPA. Falls back to the first CORS_ORIGIN if unset.
# PUBLIC_WEB_ORIGIN=https://your-frontend-domain.com
# This backend's own public origin — used to build the unsubscribe link in emails.
# PUBLIC_API_ORIGIN=https://your-backend-domain.com

# Email re-engagement (§10) — OPTIONAL. The whole system is INERT until these are
# set: with no RESEND_API_KEY, jobs just log instead of sending. To enable:
#   1. Create a Resend account (resend.com), verify a sending domain, get an API key.
#   2. Set RESEND_API_KEY + EMAIL_FROM below.
#   3. Set CRON_SECRET and schedule POST /jobs/run?type=digest|streak|rivals with the
#      header `x-cron-secret: <CRON_SECRET>` (e.g. a Render Cron Job or GitHub Action),
#      or run `npm run job:digest` manually. Without CRON_SECRET the /jobs/run endpoint
#      returns 503.
# RESEND_API_KEY=re_...
# EMAIL_FROM="FluentKeys <noreply@your-domain.com>"
# CRON_SECRET=some-long-random-string
# Optional: separate secret for signing unsubscribe links (defaults to CRON_SECRET).
# UNSUBSCRIBE_SECRET=another-long-random-string

# Backend
PORT=3001
DATABASE_URL=postgres://fluentkeys:fluentkeys@localhost:5432/fluentkeys
REDIS_URL=redis://localhost:6379
# Clerk (dashboard.clerk.com → your app → API keys)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Production only (leave unset for local dev):
# Comma-separated list of allowed browser origins. Unset = allow all.
# CORS_ORIGIN=https://your-frontend-domain.com
# Hosted Postgres (Railway/Render) requires TLS; local Docker Postgres does not.
# PGSSL=true

# Docker Compose Postgres
POSTGRES_USER=fluentkeys
POSTGRES_PASSWORD=fluentkeys
POSTGRES_DB=fluentkeys
